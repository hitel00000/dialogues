---
import '../styles/global.css';
import { COLLECTIONS, BASE_URL } from '../config';

interface Props {
  title?: string;
}

const { title = "Dialogues" } = Astro.props;
---

<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-6JB8QWCEQP"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-6JB8QWCEQP');
    </script>
  </head>

  <body>
    <aside class="sidebar">
      <div class="sidebar-top">
        <h1><a href={BASE_URL} style="text-decoration: none; color: inherit;">Dialogues</a></h1>
        <p>관심 있는 다양한 주제의 대화와 생각을 기록하는 보관소</p>
        <nav>
          <a href={`${BASE_URL}about`}>소개</a>
          {COLLECTIONS.map(col => (
            <a href={`${BASE_URL}${col.id}`}>{col.label}</a>
          ))}
        </nav>
      </div>
      <footer class="sidebar-footer">
        © 2026 hitel00000 · <a href="https://github.com/hitel00000/dialogues" target="_blank" rel="noopener noreferrer">GitHub</a>
      </footer>
    </aside>
    <main>
      <slot />
    </main>
  </body>
</html>