---
import '../styles/global.css';
import { COLLECTIONS, BASE_URL } from '../config';

interface Props {
  title?: string;
}

const { title = "Dialogues" } = Astro.props;
---

<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-6JB8QWCEQP"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-6JB8QWCEQP');
    </script>
  </head>

  <body>
    <aside class="sidebar">
      <h1><a href={BASE_URL} style="text-decoration: none; color: inherit;">Dialogues</a></h1>
      <p>관심 있는 다양한 주제의 대화와 생각을 기록하는 보관소</p>
      <nav>
        {COLLECTIONS.map(col => (
          <a href={`${BASE_URL}${col.id}`}>{col.label}</a>
        ))}
        <hr />
        <a href="https://github.com/hitel00000" target="_blank" rel="noopener noreferrer" style="opacity: 0.55;">GitHub ↗</a>
      </nav>
    </aside>
    <main>
      <slot />
    </main>
  </body>
</html>