---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const conversations = (await getCollection('conversations')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const essays = (await getCollection('essays')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;

const formatDate = (date: Date) => {
  return date.toLocaleDateString('ko-KR', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
};
---

<BaseLayout title="Dialogues - AI 에이전트와 조직 지능">
  <section>
    <h2>대화 (Conversations)</h2>
    <div class="posts-list">
      {conversations.map((post) => (
        <div class="card">
          <div class="item-heading">
            <h3>
              <a href={`${base}conversations/${post.id}`}>{post.data.title}</a>
            </h3>
            <span class="meta">{formatDate(post.data.date)}</span>
          </div>
          {post.data.description && <p class="summary">{post.data.description}</p>}
        </div>
      ))}
    </div>
  </section>

  <section>
    <h2>에세이 (Essays)</h2>
    <div class="posts-list">
      {essays.map((post) => (
        <div class="card">
          <div class="item-heading">
            <h3>
              <a href={`${base}essays/${post.id}`}>{post.data.title}</a>
            </h3>
            <span class="meta">{formatDate(post.data.date)}</span>
          </div>
          {post.data.description && <p class="summary">{post.data.description}</p>}
        </div>
      ))}
    </div>
  </section>
</BaseLayout>