---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { COLLECTIONS } from '../config';

// 1. Fetch all posts from all collections
const allPosts = [];
for (const col of COLLECTIONS) {
  const posts = await getCollection(col.id);
  allPosts.push(...posts.map(p => ({ ...p, collectionId: col.id })));
}

// 2. Sort and take the top 5 most recent posts
const recentPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Dialogues - 생각과 대화 기록">
  <section>
    <h2>최근 업데이트</h2>
    <div class="posts-list">
      {recentPosts.map((post) => (
        <PostCard post={post} collectionId={post.collectionId} base={base} />
      ))}
    </div>
  </section>

  <section>
    <h2>카테고리</h2>
    <div class="posts-list">
      <div class="card">
        <div class="item-heading">
          <h3>
            <a href={`${base}conversations`}>대화 ➔</a>
          </h3>
        </div>
        <p class="summary" style="margin-bottom: 0; font-size: 0.95rem;">
          다양한 주제에 관해 나누었던 대화의 기록
        </p>
      </div>
      <div class="card">
        <div class="item-heading">
          <h3>
            <a href={`${base}essays`}>에세이 ➔</a>
          </h3>
        </div>
        <p class="summary" style="margin-bottom: 0; font-size: 0.95rem;">
          생각을 정제하여 기록한 짧은 글들
        </p>
      </div>
    </div>
  </section>
</BaseLayout>