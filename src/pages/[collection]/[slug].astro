---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SeriesTocAccordion from '../../components/SeriesTocAccordion.astro';
import { COLLECTIONS, BASE_URL } from '../../config';
import { formatDate } from '../../utils/date';
import tocData from '../../data/structure-notes-toc.json';

export async function getStaticPaths() {
  const allPaths = await Promise.all(
    COLLECTIONS.map(async (col) => {
      const posts = await getCollection(col.id);
      return posts.map((post) => ({
        params: {
          collection: col.id,
          slug: post.id,
        },
        props: { post },
      }));
    })
  );

  return allPaths.flat();
}

const { post } = Astro.props;
const { Content } = await render(post);

// 1. 빌드 실패 방지를 위해 curated-links.json 동적 임포트 및 예외 처리
let curatedLinks = {};
try {
  const fs = await import('fs');
  const path = await import('path');
  const filePath = path.join(process.cwd(), 'src', 'data', 'curated-links.json');
  if (fs.existsSync(filePath)) {
    curatedLinks = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
  }
} catch (e) {
  console.warn("Could not load curated-links.json. Proceeding without LLM recommendations.", e);
}

// 2. 현재 포스트의 큐레이션 가져오기
const currentCuration = curatedLinks[post.id] || { internal: [], external: [] };

// 3. 모든 포스트 목록 긁어오기 (internal 추천 대상 탐색용)
const allPosts = [];
for (const col of COLLECTIONS) {
  const posts = await getCollection(col.id);
  allPosts.push(...posts.map(p => ({ ...p, collectionId: col.id })));
}

// 4. 내부 추천 포스트 매핑
const internalRecommendations = (currentCuration.internal || [])
  .map((rec) => {
    const matchedPost = allPosts.find(p => p.id === rec.id);
    if (!matchedPost) return null;
    return {
      ...matchedPost,
      reason: rec.reason
    };
  })
  .filter(Boolean);

// 5. 외부 추천 포스트 매핑
const externalRecommendations = currentCuration.external || [];

// 6. 연작 시리즈의 이전/다음 챕터 네비게이션 계산
const flatChapters = tocData.flatMap(part => part.chapters);
const currentChapterNum = post.data.chapter;
let prevChapter = null;
let nextChapter = null;
let prevPost = null;
let nextPost = null;

if (post.collection === 'structure-notes' && typeof currentChapterNum === 'number') {
  prevChapter = flatChapters.find(ch => ch.chapter === currentChapterNum - 1);
  nextChapter = flatChapters.find(ch => ch.chapter === currentChapterNum + 1);
  
  const seriesPosts = allPosts.filter(p => p.collectionId === 'structure-notes');
  if (prevChapter) {
    prevPost = seriesPosts.find(p => p.id === prevChapter.slug);
  }
  if (nextChapter) {
    nextPost = seriesPosts.find(p => p.id === nextChapter.slug);
  }
}
---

<BaseLayout title={`${post.data.title} - Dialogues`}>
{post.collection !== 'structure-notes' && (
    <nav class="back-nav">
      <a href={`${BASE_URL}${post.collection}`}>
        ← {COLLECTIONS.find(c => c.id === post.collection)?.label || '목록'} 목록으로 돌아가기
      </a>
    </nav>
  )}

  <article>
    {post.collection === 'structure-notes' && (
      <SeriesTocAccordion currentChapter={currentChapterNum} />
    )}
    
    <h1>{post.data.title}</h1>
    <div style="display: flex; align-items: center; flex-wrap: wrap; gap: 8px 12px; opacity: 0.6; font-size: 0.95rem; margin-bottom: 32px;">
      <span style="font-weight: 500; padding: 2px 8px; border-radius: 4px; background: rgba(127,127,127,0.15); font-size: 0.8rem; letter-spacing: 0.02em; white-space: nowrap;">
        {COLLECTIONS.find(c => c.id === post.collection)?.label || post.collection}
      </span>
      {typeof currentChapterNum === 'number' && (
        <>
          <span class="meta-dot">•</span>
          <span style="white-space: nowrap;">Chapter {currentChapterNum}</span>
        </>
      )}
      <span class="meta-dot">•</span>
      <span style="white-space: nowrap;">{formatDate(post.data.date)}</span>
    </div>

    <Content />

    {/* 연작 시리즈 네비게이션 */}
    {post.collection === 'structure-notes' && (prevChapter || nextChapter) && (
      <div class="series-nav" style="margin-top: 56px; border-radius: 8px; background: rgba(127,127,127,0.05); border: 1px solid var(--border);">
        {prevChapter && (
          <div class="series-nav-item prev">
            <span class="nav-label">이전 챕터</span>
            {prevPost ? (
              <a href={`${BASE_URL}structure-notes/${prevChapter.slug}`} class="nav-link">
                ← {prevChapter.title}
              </a>
            ) : (
              <span class="nav-disabled">
                <span class="nav-title">← {prevChapter.title}</span>
                <small class="nav-badge">준비중</small>
              </span>
            )}
          </div>
        )}
        
        {prevChapter && nextChapter && <div class="series-nav-divider" />}
        
        {nextChapter && (
          <div class="series-nav-item next">
            <span class="nav-label">다음 챕터</span>
            {nextPost ? (
              <a href={`${BASE_URL}structure-notes/${nextChapter.slug}`} class="nav-link">
                {nextChapter.title} →
              </a>
            ) : (
              <span class="nav-disabled">
                <span class="nav-title">{nextChapter.title} →</span>
                <small class="nav-badge">준비중</small>
              </span>
            )}
          </div>
        )}
      </div>
    )}

    {/* LLM 시맨틱 큐레이션 추천 섹션 */}
    {(internalRecommendations.length > 0 || externalRecommendations.length > 0) && (
      <div style="margin-top: 56px; padding-top: 32px; border-top: 1px solid var(--border);">
        <h3 style="font-size: 1.25rem; margin-bottom: 24px; font-weight: 700; opacity: 0.9;">
          사유의 확장: AI가 제안하는 연결고리
        </h3>
        
        {/* 내부 추천 */}
        {internalRecommendations.length > 0 && (
          <div style="margin-bottom: 32px;">
            <div style="font-size: 0.82rem; opacity: 0.6; font-weight: 600; margin-bottom: 12px; letter-spacing: 0.05em; text-transform: uppercase;">
              이 블로그의 연관 생각
            </div>
            {internalRecommendations.map((rec) => (
              <a href={`${BASE_URL}${rec.collectionId}/${rec.id}`} style="text-decoration: none; display: block; margin-bottom: 16px;">
                <div class="card" style="margin-bottom: 0; padding: 18px;">
                  <div style="display: flex; align-items: center; gap: 8px; font-size: 0.75rem; opacity: 0.6; margin-bottom: 6px;">
                    <span style="font-weight: 500; padding: 1px 6px; border-radius: 4px; background: rgba(127,127,127,0.15);">
                      {COLLECTIONS.find(c => c.id === rec.collectionId)?.label}
                    </span>
                    <span>•</span>
                    <span>{formatDate(rec.data.date)}</span>
                  </div>
                  <h4 style="margin: 0 0 8px; font-size: 1rem; line-height: 1.45; font-weight: 600;">
                    {rec.data.title}
                  </h4>
                  <p style="margin: 0; font-size: 0.88rem; opacity: 0.8; line-height: 1.6; font-style: italic;">
                    &ldquo;{rec.reason}&rdquo;
                  </p>
                </div>
              </a>
            ))}
          </div>
        )}

        {/* 외부 추천 */}
        {externalRecommendations.length > 0 && (
          <div>
            <div style="font-size: 0.82rem; opacity: 0.6; font-weight: 600; margin-bottom: 12px; letter-spacing: 0.05em; text-transform: uppercase;">
              인터넷 지식의 바다로 확장하기
            </div>
            {externalRecommendations.map((rec) => (
              <a href={rec.url} target="_blank" rel="noopener noreferrer" style="text-decoration: none; display: block; margin-bottom: 16px;">
                <div class="card" style="margin-bottom: 0; padding: 18px; border-left: 3px solid rgba(127,127,127,0.35);">
                  <div style="font-size: 0.72rem; opacity: 0.6; margin-bottom: 6px; font-weight: 500; letter-spacing: 0.02em;">
                    🌐 EXTERNAL ARTICLE ↗
                  </div>
                  <h4 style="margin: 0 0 8px; font-size: 1rem; line-height: 1.45; font-weight: 600;">
                    {rec.title}
                  </h4>
                  <p style="margin: 0; font-size: 0.88rem; opacity: 0.8; line-height: 1.6; font-style: italic;">
                    &ldquo;{rec.reason}&rdquo;
                  </p>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    )}

    {post.data.tags && post.data.tags.length > 0 && (
      <footer style="margin-top: 56px; padding-top: 24px; border-top: 1px solid var(--border);">
        <div style="opacity: 0.6; font-size: 0.95rem; margin-bottom: 12px;">태그</div>
        <div class="focus-tags" style="margin-top: 0;">
          {post.data.tags.map((tag: string) => (
            <a href={`${BASE_URL}tags/${tag}`} style="text-decoration: none;">
              <span>#{tag}</span>
            </a>
          ))}
        </div>
      </footer>
    )}
  </article>
</BaseLayout>

<style>
  .series-nav {
    display: flex;
    justify-content: space-between;
    align-items: stretch;
    gap: 0;
  }
  .series-nav-item {
    flex: 1;
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .series-nav-item.prev {
    text-align: left;
  }
  .series-nav-item.next {
    text-align: right;
  }
  .series-nav-divider {
    width: 1px;
    background: var(--border);
    align-self: stretch;
  }
  .nav-label {
    font-size: 0.75rem;
    opacity: 0.5;
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 6px;
  }
  .nav-link {
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    color: inherit;
    line-height: 1.4;
  }
  .nav-link:hover {
    text-decoration: underline;
  }
  .nav-disabled {
    font-size: 0.95rem;
    opacity: 0.35;
    cursor: not-allowed;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    line-height: 1.4;
  }
  .series-nav-item.next .nav-disabled {
    flex-direction: row-reverse;
  }
  .nav-title {
    word-break: keep-all;
  }
  .nav-badge {
    font-size: 0.72rem;
    padding: 1px 5px;
    border-radius: 4px;
    background: rgba(127, 127, 127, 0.15);
    font-weight: 500;
    white-space: nowrap;
    display: inline-block;
  }

  @media (max-width: 600px) {
    .series-nav {
      flex-direction: column;
    }
    .series-nav-item {
      padding: 18px 20px;
    }
    .series-nav-item.next {
      text-align: left;
    }
    .series-nav-item.next .nav-disabled {
      flex-direction: row;
    }
    .series-nav-divider {
      width: 100%;
      height: 1px;
      align-self: auto;
    }
    .meta-dot {
      display: none;
    }
  }
</style>