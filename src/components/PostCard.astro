---
interface Props {
  post: any;
  collectionId: string;
  base: string;
}

const { post, collectionId, base } = Astro.props;

const formatDate = (date: Date) => {
  return date.toLocaleDateString('ko-KR', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
  });
};
---

<div class="card">
  <div class="item-heading">
    <h3>
      <a href={`${base}${collectionId}/${post.id}`}>{post.data.title}</a>
    </h3>
    <span class="meta">{formatDate(post.data.date)}</span>
  </div>
  {post.data.description && <p class="summary">{post.data.description}</p>}
  
  {post.data.tags && post.data.tags.length > 0 && (
    <div class="focus-tags">
      {post.data.tags.map((tag: string) => (
        <a href={`${base}tags/${tag}`} style="text-decoration: none;">
          <span>#{tag}</span>
        </a>
      ))}
    </div>
  )}
</div>
