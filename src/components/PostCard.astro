---
import { BASE_URL, COLLECTIONS } from '../config';
import { formatDate } from '../utils/date';

interface Props {
  post: any;
  collectionId: string;
}

const { post, collectionId } = Astro.props;
---

<div class="card">
  <div class="item-heading">
    <h3>
      <a href={`${BASE_URL}${collectionId}/${post.id}`}>{post.data.title}</a>
    </h3>
    <div class="meta" style="display: inline-flex; align-items: center; gap: 6px;">
      <span style="font-weight: 500; padding: 2px 6px; border-radius: 4px; background: rgba(127,127,127,0.15); font-size: 0.72rem; opacity: 0.95;">
        {COLLECTIONS.find(c => c.id === collectionId)?.label || collectionId}
      </span>
      <span>•</span>
      <span>{formatDate(post.data.date)}</span>
    </div>
  </div>
  {post.data.description && <p class="summary">{post.data.description}</p>}
  
  {post.data.tags && post.data.tags.length > 0 && (
    <div class="focus-tags">
      {post.data.tags.map((tag: string) => (
        <a href={`${BASE_URL}tags/${tag}`} style="text-decoration: none;">
          <span>#{tag}</span>
        </a>
      ))}
    </div>
  )}
</div>
