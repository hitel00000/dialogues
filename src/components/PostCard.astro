---
import { BASE_URL } from '../config';
import { formatDate } from '../utils/date';

interface Props {
  post: any;
  collectionId: string;
}

const { post, collectionId } = Astro.props;
---

<div class="card">
  <div class="item-heading">
    <h3>
      <a href={`${BASE_URL}${collectionId}/${post.id}`}>{post.data.title}</a>
    </h3>
    <span class="meta">{formatDate(post.data.date)}</span>
  </div>
  {post.data.description && <p class="summary">{post.data.description}</p>}
  
  {post.data.tags && post.data.tags.length > 0 && (
    <div class="focus-tags">
      {post.data.tags.map((tag: string) => (
        <a href={`${BASE_URL}tags/${tag}`} style="text-decoration: none;">
          <span>#{tag}</span>
        </a>
      ))}
    </div>
  )}
</div>
